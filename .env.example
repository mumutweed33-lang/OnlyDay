NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth provider: mock | supabase | custom
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Payments provider: mock | mercado_pago
NEXT_PUBLIC_PAYMENTS_PROVIDER=mock

# Server auth secret (only needed if you later plug a custom server-side auth flow)
AUTH_SECRET=change-me

# Database connection (optional if you only use Supabase Auth + metadata)
DATABASE_URL=

# Supabase browser client
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional server/admin key for future API routes and background jobs
SUPABASE_SERVICE_ROLE_KEY=

# Real PIX checkout with Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_URL=
